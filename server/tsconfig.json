{
  "compilerOptions": {
    "target": "ES2021",
    "module": "Node16",
    "lib": ["esnext"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test-db*.ts"]
}
