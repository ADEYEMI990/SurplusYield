generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

// ========== USER MODEL ==========
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         String   @default("user") // "user" | "admin"
  status       String   @default("active") // "active" | "disabled"
  kycStatus    String   @default("pending") // "pending" | "approved" | "rejected"
  referralCode String?  @unique
  referredBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  investments    Investment[]
  transactions   Transaction[]
  notifications  Notification[]
  rewards        Reward[]
  kycSubmissions KycSubmission[]
  withdrawWallet WithdrawWallet?
  spotlights     Spotlight[]

  @@index([email])
  @@index([referralCode])
}

// ========== PLAN MODEL ==========
model Plan {
  id             String   @id @default(cuid())
  icon           String?
  name           String   @unique
  badge          String
  planType       String   @default("range") // "fixed" | "range"
  minAmount      Decimal? @db.Decimal(10, 2)
  maxAmount      Decimal? @db.Decimal(10, 2)
  amount         Decimal? @db.Decimal(10, 2)
  roiType        String   @default("range") // "fixed" | "range"
  roiValue       Decimal? @db.Decimal(5, 2)
  minRoi         Decimal? @db.Decimal(5, 2)
  maxRoi         Decimal? @db.Decimal(5, 2)
  roiUnit        String   @default("%") // "%" | "$"
  returnPeriod   String   @default("daily") // "hour" | "daily" | "weekly"
  returnType     String   @default("period") // "period" | "lifetime"
  numOfPeriods   Int?
  holidays       String[] @default([]) // ["saturday", "sunday"]
  capitalBack    Boolean  @default(true)
  featured       Boolean  @default(true)
  canCancel      Boolean  @default(false)
  trending       Boolean  @default(false)
  status         String   @default("active") // "active" | "deactivated"
  durationInDays Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  investments  Investment[]
  transactions Transaction[]

  @@index([status])
}

// ========== INVESTMENT MODEL ==========
model Investment {
  id            String    @id @default(cuid())
  userId        String
  planId        String
  amount        Decimal   @db.Decimal(10, 2)
  initialAmount Decimal   @db.Decimal(10, 2)
  roiRate       Decimal   @db.Decimal(5, 2)
  roiInterval   String    @default("daily") // "daily" | "weekly" | "monthly"
  roiType       String    @default("flat") // "flat" | "compounded"
  startDate     DateTime  @default(now())
  endDate       DateTime?
  lastCredited  DateTime?
  status        String    @default("active") // "active" | "completed"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  roiEarned     Decimal   @default(0) @db.Decimal(10, 2)
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan      @relation(fields: [planId], references: [id])

  transactions Transaction[]

  @@index([userId])
  @@index([planId])
  @@index([status])
}

// ========== TRANSACTION MODEL ==========
model Transaction {
  id             String    @id @default(cuid())
  userId         String
  planId         String?
  investmentId   String?
  type           String // "deposit" | "withdrawal" | "investment" | "profit" | "roi" | "bonus" | "capitalReturn"
  amount         Decimal   @db.Decimal(10, 2)
  status         String    @default("pending") // "pending" | "success" | "failed" | "completed"
  reference      String    @unique
  bonusType      String? // "referral" | "deposit" | "investment" | "signup"
  receipt        String?
  currency       String    @default("USD")
  nextPayoutAt   DateTime?
  lastRoiAt      DateTime?
  roiLock        Boolean   @default(false)
  roiLockUntil   DateTime?
  durationInDays Int?
  isCompleted    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       Plan?       @relation(fields: [planId], references: [id])
  investment Investment? @relation(fields: [investmentId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([reference])
}

// ========== ADMIN MODEL ==========
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("admin") // "superadmin" | "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ========== KYC FORM MODEL ==========
model KycForm {
  id        String   @id @default(cuid())
  name      String
  fields    Json     @default("[]") // Array of {label, type, required}
  status    String   @default("active") // "active" | "deactivated"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  submissions KycSubmission[]
}

// ========== KYC SUBMISSION MODEL ==========
model KycSubmission {
  id        String   @id @default(cuid())
  userId    String
  formId    String
  fields    Json     @default("[]") // Array of {label, value}
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  form KycForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([formId])
  @@index([status])
}

// ========== WALLET MODEL ==========
model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== WITHDRAW WALLET MODEL ==========
model WithdrawWallet {
  id         String   @id @default(cuid())
  userId     String   @unique
  btcAddress String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ========== NOTIFICATION MODEL ==========
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("system") // "investment" | "transaction" | "kyc" | "security" | "system"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

// ========== REWARD MODEL ==========
model Reward {
  id        String   @id @default(cuid())
  userId    String
  type      String // "earning" | "redeem"
  points    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ========== SETTING MODEL ==========
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== SPOTLIGHT MODEL ==========
model Spotlight {
  id        String    @id @default(cuid())
  type      String // "investment" | "withdraw"
  title     String
  subtitle  String?
  date      DateTime?
  status    String?
  net       String?
  total     String?
  amount    Decimal?  @db.Decimal(10, 2)
  meta      Json?
  order     Int       @default(0)
  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  user User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdBy])
}

// ========== TEMPLATE MODEL ==========
model Template {
  id        String   @id @default(cuid())
  type      String // "email" | "sms" | "push"
  name      String   @unique
  subject   String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}
